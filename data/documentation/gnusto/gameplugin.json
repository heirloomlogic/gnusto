{"hierarchy":{"paths":[["doc:\/\/Gnusto\/documentation\/Gnusto"]]},"sections":[],"topicSections":[{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin\/actions","doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin\/rules","doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin\/verbs"]}],"seeAlsoSections":[{"generated":true,"anchor":"Composing-Large-Games","title":"Composing Large Games","identifiers":["doc:\/\/Gnusto\/documentation\/Gnusto\/SplittingAGameAcrossFiles","doc:\/\/Gnusto\/documentation\/Gnusto\/ContentBundles","doc:\/\/Gnusto\/documentation\/Gnusto\/Plugins","doc:\/\/Gnusto\/documentation\/Gnusto\/GameContent","doc:\/\/Gnusto\/documentation\/Gnusto\/GameContents"]}],"relationshipsSections":[{"identifiers":["doc:\/\/Gnusto\/s8SendableP","doc:\/\/Gnusto\/s16SendableMetatypeP"],"type":"inheritsFrom","kind":"relationships","title":"Inherits From"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"navigatorTitle":[{"text":"GamePlugin","kind":"identifier"}],"externalID":"s:6Gnusto10GamePluginP","title":"GamePlugin","role":"symbol","symbolKind":"protocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"GamePlugin"}],"modules":[{"name":"Gnusto"}],"roleHeading":"Protocol"},"identifier":{"url":"doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GamePlugin","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"Sendable","kind":"typeIdentifier","preciseIdentifier":"s:s8SendableP"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/Gnusto\/documentation\/Gnusto\/Plugins","doc:\/\/Gnusto\/documentation\/Gnusto\/AddingCustomVerbs"]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"inlineContent":[{"text":"A plugin bundles the player-typeable vocabulary a system needs (","type":"text"},{"code":"buy","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"attack","type":"codeVoice"},{"text":", ","type":"text"},{"code":"ask","type":"codeVoice"},{"text":") with the logic that reacts to it, so the system can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"shipped once and reused instead of hand-copied into every game."}],"type":"paragraph"},{"type":"codeListing","code":["struct CommercePlugin: GamePlugin {","    static let buy = Intent(\"buy\")","","    var verbs: [SyntaxRule] {","        SyntaxRule(\"buy\", .directObject, intent: Self.buy)","    }","}"],"syntax":"swift"},{"anchor":"Logic-only-a-plugin-owns-no-state","type":"heading","text":"Logic-only: a plugin owns no state","level":2},{"inlineContent":[{"text":"Unlike a ","type":"text"},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GameContent","isActive":true},{"text":" bundle, a plugin is ","type":"text"},{"inlineContent":[{"text":"not","type":"text"}],"type":"strong"},{"text":" reflected by the","type":"text"},{"text":" ","type":"text"},{"text":"bootstrap, so it declares no rooms, items, or ","type":"text"},{"code":"@Global","type":"codeVoice"},{"text":" state of its own. It","type":"text"},{"text":" ","type":"text"},{"text":"operates entirely over entities and globals the ","type":"text"},{"inlineContent":[{"type":"text","text":"host"}],"type":"strong"},{"text":" declares, receiving","type":"text"},{"type":"text","text":" "},{"type":"text","text":"what it needs as parameters. That keeps a plugin portable: it makes no"},{"text":" ","type":"text"},{"type":"text","text":"assumptions about the host’s world beyond the traits and intents it agrees"},{"type":"text","text":" "},{"type":"text","text":"on. A plugin that genuinely needs to ship its own content is a"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GameContent","isActive":true},{"text":" bundle instead (list it in the game’s ","type":"text"},{"code":"content","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"},{"anchor":"The-host-opts-in-by-splicing","type":"heading","text":"The host opts in by splicing","level":2},{"type":"paragraph","inlineContent":[{"text":"The host stores the plugin as a plain property and splices its vocabulary,","type":"text"},{"text":" ","type":"text"},{"text":"default actions, and rules into its own blocks. ","type":"text"},{"code":"verbs","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"actions","type":"codeVoice"},{"text":" each","type":"text"},{"text":" ","type":"text"},{"text":"merge just like a game’s own, and the plugin’s rule factories return","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Rules","isActive":true},{"text":" the host composes in. Together, ","type":"text"},{"type":"codeVoice","code":"verbs"},{"text":" + ","type":"text"},{"type":"codeVoice","code":"actions"},{"text":" let a plugin","type":"text"},{"text":" ","type":"text"},{"text":"ship a whole verb behavior — vocabulary and stage-4 default — without any","type":"text"},{"text":" ","type":"text"},{"text":"host rules at all; a host only needs its own rules to embellish or","type":"text"},{"text":" ","type":"text"},{"text":"override that default for specific entities.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["struct LampShop: Game {","    let commerce = CommercePlugin()","    @Global var purse = Purse(coins: 10)","    let lantern = Item { name(\"brass lantern\"); trait(.price, 5) }","","    var verbs: [SyntaxRule] { commerce.verbs }","    var rules: Rules {","        commerce.purchase(of: lantern,","                          balance: { purse.coins },","                          charge:  { purse.coins -= $0 })","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The protocol’s own ","type":"text"},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin\/rules","isActive":true},{"type":"text","text":" requirement carries only self-contained,"},{"type":"text","text":" "},{"text":"world-scoped rules that need nothing from the host. Rules that must reference","type":"text"},{"text":" ","type":"text"},{"text":"host entities are exposed as ","type":"text"},{"type":"strong","inlineContent":[{"text":"parameterized methods","type":"text"}]},{"type":"text","text":" returning "},{"isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Rules","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"purchase(of:balance:charge:)"},{"text":" above), which the host calls with its own","type":"text"},{"text":" ","type":"text"},{"text":"declarations — every line still readable in the host’s source.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gnusto\/gameplugin"]}],"abstract":[{"text":"A reusable game system — commerce, combat, dialog, magic — packaged as an","type":"text"},{"text":" ","type":"text"},{"text":"importable unit of ","type":"text"},{"inlineContent":[{"type":"text","text":"verbs"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"rules","type":"text"}],"type":"emphasis"},{"text":", that a host game opts into.","type":"text"}],"references":{"doc://Gnusto/s16SendableMetatypeP":{"identifier":"doc:\/\/Gnusto\/s16SendableMetatypeP","type":"unresolvable","title":"Swift.SendableMetatype"},"doc://Gnusto/documentation/Gnusto":{"role":"collection","kind":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto","type":"topic","title":"Gnusto","url":"\/documentation\/gnusto","abstract":[{"type":"text","text":"A Swift engine for writing parser-driven interactive fiction — text adventures in the tradition of Zork and Infocom’s ZIL."}]},"doc://Gnusto/documentation/Gnusto/GamePlugin/actions":{"title":"actions","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin\/actions","abstract":[{"text":"Stage-4 default actions the plugin contributes, in the same form as a","type":"text"},{"text":" ","type":"text"},{"text":"game’s ","type":"text"},{"code":"actions","type":"codeVoice"},{"type":"text","text":". Defaults to empty. Precedence runs built-ins <"},{"text":" ","type":"text"},{"type":"text","text":"bundles\/plugins < host game, so a host action for the same intent beats"},{"text":" ","type":"text"},{"text":"this one — and this is what lets a plugin’s verbs (like Phase 8’s","type":"text"},{"text":" ","type":"text"},{"text":"combat ","type":"text"},{"type":"codeVoice","code":"attack"},{"type":"text","text":") actually do something by default, not just parse."}],"kind":"symbol","type":"topic","role":"symbol","defaultImplementations":1,"required":true,"url":"\/documentation\/gnusto\/gameplugin\/actions","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"actions"},{"kind":"text","text":": ["},{"text":"IntentAction","kind":"typeIdentifier","preciseIdentifier":"s:6Gnusto12IntentActionV"},{"text":"]","kind":"text"}]},"doc://Gnusto/documentation/Gnusto/GamePlugin/verbs":{"abstract":[{"type":"text","text":"Player-typeable verbs the plugin contributes, in the same form as a"},{"type":"text","text":" "},{"type":"text","text":"game’s "},{"type":"codeVoice","code":"verbs"},{"type":"text","text":". Defaults to empty. Precedence runs built-ins <"},{"type":"text","text":" "},{"type":"text","text":"bundles\/plugins < host game, so a host verb of the same shape beats"},{"type":"text","text":" "},{"type":"text","text":"this one."}],"title":"verbs","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin\/verbs","role":"symbol","defaultImplementations":1,"required":true,"type":"topic","url":"\/documentation\/gnusto\/gameplugin\/verbs","f