{"identifier":{"url":"doc:\/\/Gnusto\/documentation\/Gnusto\/AddingCustomVerbs","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","metadata":{"role":"article","title":"Adding Custom Verbs","roleHeading":"Article","modules":[{"name":"Gnusto"}]},"seeAlsoSections":[{"identifiers":["doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule"],"generated":true,"title":"Adding Vocabulary","anchor":"Adding-Vocabulary"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Gnusto ships with a standard verb table: "},{"type":"codeVoice","code":"take"},{"type":"text","text":", "},{"type":"codeVoice","code":"drop"},{"type":"text","text":", "},{"type":"codeVoice","code":"examine"},{"type":"text","text":", "},{"type":"codeVoice","code":"wear"},{"type":"text","text":", "},{"type":"codeVoice","code":"go"},{"type":"text","text":", "},{"type":"codeVoice","code":"look"},{"type":"text","text":", and their synonyms. When your game needs a verb of its own — "},{"type":"codeVoice","code":"ring"},{"type":"text","text":", "},{"type":"codeVoice","code":"buy"},{"type":"text","text":", "},{"type":"codeVoice","code":"dig"},{"type":"text","text":", "},{"type":"codeVoice","code":"pull"},{"type":"text","text":" — you add a row to the parser with a "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule","isActive":true},{"type":"text","text":" and handle the resulting "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent","isActive":true},{"type":"text","text":" in a rule."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are two halves to a custom verb: teaching the parser to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"recognize"}]},{"type":"text","text":" it, and writing a rule to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"respond"}]},{"type":"text","text":" to it."}]},{"type":"heading","level":2,"text":"Declare the verb","anchor":"Declare-the-verb"},{"type":"paragraph","inlineContent":[{"type":"text","text":"List new verbs in your game’s "},{"type":"codeVoice","code":"verbs"},{"type":"text","text":" block. Each "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule","isActive":true},{"type":"text","text":" pairs a verb word (or words) with the sentence shape it accepts and the "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent","isActive":true},{"type":"text","text":" it produces on a match:"}]},{"type":"codeListing","syntax":"swift","code":["struct Temple: Game {","    static let ring = Intent(\"ring\")","","    let bell = Item { name(\"brass bell\") }","","    var verbs: [SyntaxRule] {","        SyntaxRule(\"ring\", slots: .direct, intent: Self.ring)","    }","    \/\/ rules below","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Exposing the intent as a "},{"type":"codeVoice","code":"static let"},{"type":"text","text":" constant lets your rules refer to the same intent the verb emits, without re-spelling the string."}]},{"type":"heading","level":2,"text":"Choose a sentence shape","anchor":"Choose-a-sentence-shape"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"slots"},{"type":"text","text":" parameter is the shape the parser expects "},{"type":"emphasis","inlineContent":[{"type":"text","text":"after"}]},{"type":"text","text":" the verb word. The cases of "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots","isActive":true},{"type":"text","text":" cover the common patterns:"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Slots"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Player types"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Command gets"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots\/none","type":"reference","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pray"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"just the intent"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots\/direction","type":"reference","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"dig down"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"a "},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/direction","type":"reference","isActive":true}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots\/direct","type":"reference","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ring bell"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"a "},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/directObject","type":"reference","isActive":true}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots\/directThenParticle(_:)","type":"reference","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pick bell up"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"direct object, trailing particle"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots\/directPrepIndirect(_:)","type":"reference","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"put bell on hook"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"direct + indirect objects"}]}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A rule can carry several verb tokens for one shape — "},{"type":"codeVoice","code":"SyntaxRule(\"look\", \"at\", slots: .direct, intent: .examine)"},{"type":"text","text":" matches "},{"type":"codeVoice","code":"look at bell"},{"type":"text","text":". You can register several rows for one intent to give the player synonyms:"}]},{"type":"codeListing","syntax":"swift","code":["var verbs: [SyntaxRule] {","    SyntaxRule(\"ring\",  slots: .direct, intent: Self.ring)","    SyntaxRule(\"sound\", slots: .direct, intent: Self.ring)","    SyntaxRule(\"chime\", slots: .direct, intent: Self.ring)","}"]},{"type":"heading","level":2,"text":"Respond to the intent","anchor":"Respond-to-the-intent"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A custom intent has no built-in default action, so a bare "},{"type":"codeVoice","code":"ring bell"},{"type":"text","text":" would just report that the game didn’t understand. Give it behavior with a "},{"type":"codeVoice","code":"before"},{"type":"text","text":" rule that "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/reply(_:)","isActive":true},{"type":"text","text":"s — "},{"type":"codeVoice","code":"reply"},{"type":"text","text":" handles the action in place of any default:"}]},{"type":"codeListing","syntax":"swift","code":["var rules: Rules {","    bell.before(Self.ring) {","        try reply(\"The bell tolls, deep and sonorous. Somewhere, a door unlatches.\")","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the object resolved into "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/directObject","isActive":true},{"type":"text","text":", you can attach the rule to the object ("},{"type":"codeVoice","code":"bell.before(…)"},{"type":"text","text":") or handle the intent more broadly on the "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/World","isActive":true},{"type":"text","text":" when several objects share behavior:"}]},{"type":"codeListing","syntax":"swift","code":["world.before(Self.ring) {","    guard let thing = command.directObject else {","        try refuse(\"Ring what?\")","    }","    try reply(\"You ring the \\(thing.name). Nothing happens.\")","}"]},{"type":"heading","level":2,"text":"Reclaiming a built-in verb","anchor":"Reclaiming-a-built-in-verb"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A verb table merges the built-in rows, each content bundle’s, each plugin’s, and the game’s own, under a "},{"type":"strong","inlineContent":[{"type":"text","text":"last-wins"}]},{"type":"text","text":" policy keyed on what the player types (the verb tokens plus the slot shape). If your row’s verb and shape exactly match a built-in, yours reclaims it — the parser emits "},{"type":"emphasis","inlineContent":[{"type":"text","text":"your"}]},{"type":"text","text":" intent instead — and the engine logs a non-fatal warning so the override is never silent. This lets a game repurpose, say, "},{"type":"codeVoice","code":"read"},{"type":"text","text":" without forking the engine."}]},{"type":"heading","level":2,"text":"Where verbs can come from","anchor":"Where-verbs-can-come-from"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"verbs"},{"type":"text","text":" block exists on more than the game type. A "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GameContent","isActive":true},{"type":"text","text":" bundle and a "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin","isActive":true},{"type":"text","text":" each carry their own "},{"type":"codeVoice","code":"verbs"},{"type":"text","text":", all merged into one table at startup. That is exactly how a reusable commerce plugin ships "},{"type":"codeVoice","code":"buy"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"sell"},{"type":"text","text":" for any host to splice in — see "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Plugins","isActive":true},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"See also","anchor":"See-also"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules","isActive":true,"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline","isActive":true,"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Plugins","isActive":true,"type":"reference"}]}]}]}]}],"abstract":[{"type":"text","text":"Teach the parser words the built-in table doesn’t know."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gnusto\/addingcustomverbs"]}],"hierarchy":{"paths":[["doc:\/\/Gnusto\/documentation\/Gnusto"]]},"references":{"doc://Gnusto/documentation/Gnusto/SyntaxRule/Slots/directThenParticle(_:)":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots\/directThenParticle(_:)","url":"\/documentation\/gnusto\/syntaxrule\/slots\/directthenparticle(_:)","kind":"symbol","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"directThenParticle","kind":"identifier"},{"text":"(","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":")","kind":"text"}],"title":"SyntaxRule.Slots.directThenParticle(_:)","abstract":[{"type":"codeVoice","code":"pick cloak up"},{"type":"text","text":", "},{"type":"codeVoice","code":"take cloak off"},{"type":"text","text":" — direct object then a trailing particle"}]},"doc://Gnusto/documentation/Gnusto/SyntaxRule/Slots/directPrepIndirect(_:)":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots\/directPrepIndirect(_:)","url":"\/documentation\/gnusto\/syntaxrule\/slots\/directprepindirect(_:)","kind":"symbol","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"directPrepIndirect","kind":"identifier"},{"text":"(","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":")","kind":"text"}],"title":"SyntaxRule.Slots.directPrepIndirect(_:)","abstract":[{"type":"codeVoice","code":"put cloak on hook"},{"type":"text","text":", "},{"type":"codeVoice","code":"hang cloak on hook"}]},"doc://Gnusto/documentation/Gnusto/SyntaxRule/Slots/direction":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots\/direction","url":"\/documentation\/gnusto\/syntaxrule\/slots\/direction","kind":"symbol","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"direction","kind":"identifier"}],"title":"SyntaxRule.Slots.direction","abstract":[{"type":"codeVoice","code":"go north"}]},"doc://Gnusto/documentation/Gnusto/SyntaxRule/Slots/none":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots\/none","type":"topic","kind":"symbol","title":"SyntaxRule.Slots.none","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"none","kind":"identifier"}],"abstract":[{"code":"look","type":"codeVoice"},{"type":"text","text":", "},{"code":"inventory","type":"codeVoice"},{"type":"text","text":", "},{"code":"score","type":"codeVoice"}],"url":"\/documentation\/gnusto\/syntaxrule\/slots\/none"},"doc://Gnusto/documentation/Gnusto/Command/direction":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/direction","type":"topic","kind":"symbol","title":"direction","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"direction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Direction","preciseIdentifier":"s:6Gnusto9DirectionO"},{"kind":"text","text":"?"}],"abstract":[{"type":"text","text":"The direction the player named, if any."}],"url":"\/documentation\/gnusto\/command\/direction"},"doc://Gnusto/documentation/Gnusto/Plugins":{"role":"article","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Plugins","type":"topic","kind":"article","title":"Plugins","abstract":[{"type":"text","text":"Package a reusable game system as an importable unit of verbs and rules."}],"url":"\/documentation\/gnusto\/plugins"},"doc://Gnusto/documentation/Gnusto/reply(_:)":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/reply(_:)","type":"topic","kind":"symbol","title":"reply(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reply"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Never","preciseIdentifier":"s:s5NeverO"}],"abstract":[{"type":"text","text":"Fully handles the current action with a response, skipping the default"},{"type":"text","text":" "},{"type":"text","text":"behavior. Mechanically identical to "},{"type":"codeVoice","code":"refuse(_:)"},{"type":"text","text":" — two names exist so"},{"type":"text","text":" "},{"type":"text","text":"game code reads correctly: "},{"type":"codeVoice","code":"refuse"},{"type":"text","text":" for “no, you can’t”, "},{"type":"codeVoice","code":"reply"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"“here’s what happens instead”."}],"url":"\/documentation\/gnusto\/reply(_:)"},"doc://Gnusto/documentation/Gnusto/Intent":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent","type":"topic","kind":"symbol","title":"Intent","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Intent"}],"abstract":[{"type":"text","text":"A canonical action the player can attempt. Games can mint their own"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"Intent(\"ring\")"},{"type":"text","text":") and register verbs and default behavior for them."}],"url":"\/documentation\/gnusto\/intent","navigatorTitle":[{"kind":"identifier","text":"Intent"}]},"doc://Gnusto/documentation/Gnusto":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto","url":"\/documentation\/gnusto","kind":"symbol","role":"collection","abstract":[{"type":"text","text":"A Swift engine for writing parser-driven interactive fiction — text adventures in the tradition of Zork and Infocom’s ZIL."}],"title":"Gnusto"},"doc://Gnusto/documentation/Gnusto/Command/directObject":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/directObject","type":"topic","kind":"symbol","title":"directObject","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"directObject"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Item","preciseIdentifier":"s:6Gnusto4ItemV"},{"kind":"text","text":"?"}],"abstract":[{"type":"text","text":"The primary item the command acts on, if any."}],"url":"\/documentation\/gnusto\/command\/directobject"},"doc://Gnusto/documentation/Gnusto/World":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/World","type":"topic","kind":"symbol","title":"World","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"World"}],"abstract":[{"type":"text","text":"Rules that apply everywhere, declared through the "},{"type":"codeVoice","code":"world"},{"type":"text","text":" identifier in a"},{"type":"text","text":" "},{"type":"codeVoice","code":"rules"},{"type":"text","text":" block:"}],"url":"\/documentation\/gnusto\/world","navigatorTitle":[{"kind":"identifier","text":"World"}]},"doc://Gnusto/documentation/Gnusto/WritingRules":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules","url":"\/documentation\/gnusto\/writingrules","kind":"article","role":"article","title":"Writing Rules","abstract":[{"type":"text","text":"Attach game logic to items, locations, and the world."}]},"doc://Gnusto/documentation/Gnusto/SyntaxRule/Slots/direct":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots\/direct","url":"\/documentation\/gnusto\/syntaxrule\/slots\/direct","kind":"symbol","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"direct","kind":"identifier"}],"title":"SyntaxRule.Slots.direct","abstract":[{"type":"codeVoice","code":"take cloak"}]},"doc://Gnusto/documentation/Gnusto/TheTurnPipeline":{"role":"article","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline","type":"topic","kind":"article","title":"The Turn Pipeline","abstract":[{"type":"text","text":"What happens between the player pressing Return and the next prompt."}],"url":"\/documentation\/gnusto\/theturnpipeline"},"doc://Gnusto/documentation/Gnusto/SyntaxRule":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule","type":"topic","kind":"symbol","title":"SyntaxRule","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SyntaxRule"}],"abstract":[{"type":"text","text":"One row of the verb table: a verb token sequence, the sentence shape it"},{"type":"text","text":" "},{"type":"text","text":"accepts, and the intent it produces. Data, not code — games can add rows"},{"type":"text","text":" "},{"type":"text","text":"through their "},{"type":"codeVoice","code":"verbs"},{"type":"text","text":" block to teach the parser new player-typeable verbs."}],"url":"\/documentation\/gnusto\/syntaxrule","navigatorTitle":[{"kind":"identifier","text":"SyntaxRule"}]},"doc://Gnusto/documentation/Gnusto/GamePlugin":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin","type":"topic","kind":"symbol","title":"GamePlugin","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"GamePlugin"}],"abstract":[{"type":"text","text":"A reusable game system — commerce, combat, dialog, magic — packaged as an"},{"type":"text","text":" "},{"type":"text","text":"importable unit of "},{"type":"emphasis","inlineContent":[{"type":"text","text":"verbs"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"rules"}]},{"type":"text","text":", that a host game opts into."}],"url":"\/documentation\/gnusto\/gameplugin","navigatorTitle":[{"kind":"identifier","text":"GamePlugin"}]},"doc://Gnusto/documentation/Gnusto/GameContent":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GameContent","type":"topic","kind":"symbol","title":"GameContent","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"GameContent"}],"abstract":[{"type":"text","text":"A self-contained slice of a game’s world: its own rooms, items, and"},{"type":"text","text":" "},{"type":"codeVoice","code":"@Global"},{"type":"text","text":" state, plus the geography, rules, and verbs that go with them."}],"url":"\/documentation\/gnusto\/gamecontent","navigatorTitle":[{"kind":"identifier","text":"GameContent"}]},"doc://Gnusto/documentation/Gnusto/SyntaxRule/Slots":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule\/Slots","type":"topic","kind":"symbol","title":"SyntaxRule.Slots","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Slots","kind":"identifier"}],"abstract":[{"type":"text","text":"The sentence shape a verb accepts after its verb tokens."}],"url":"\/documentation\/gnusto\/syntaxrule\/slots","navigatorTitle":[{"text":"Slots","kind":"identifier"}]}}}