{"abstract":[{"text":"Teach the parser words the built-in table doesn’t know.","type":"text"}],"variants":[{"paths":["\/documentation\/gnusto\/addingcustomverbs"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Gnusto\/documentation\/Gnusto\/AddingCustomVerbs"},"sections":[],"metadata":{"modules":[{"name":"Gnusto"}],"role":"article","roleHeading":"Article","title":"Adding Custom Verbs"},"hierarchy":{"paths":[["doc:\/\/Gnusto\/documentation\/Gnusto"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"anchor":"Adding-Vocabulary","title":"Adding Vocabulary","identifiers":["doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule","doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxElement"],"generated":true}],"kind":"article","primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"Gnusto ships with a standard verb table: ","type":"text"},{"type":"codeVoice","code":"take"},{"text":", ","type":"text"},{"type":"codeVoice","code":"drop"},{"text":", ","type":"text"},{"type":"codeVoice","code":"examine"},{"text":", ","type":"text"},{"type":"codeVoice","code":"wear"},{"text":", ","type":"text"},{"type":"codeVoice","code":"go"},{"text":", ","type":"text"},{"type":"codeVoice","code":"look"},{"text":", and their synonyms. When your game needs a verb of its own — ","type":"text"},{"type":"codeVoice","code":"ring"},{"text":", ","type":"text"},{"type":"codeVoice","code":"buy"},{"text":", ","type":"text"},{"type":"codeVoice","code":"dig"},{"text":", ","type":"text"},{"type":"codeVoice","code":"pull"},{"text":" — you add a row to the parser with a ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule","type":"reference","isActive":true},{"text":" and handle the resulting ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent","type":"reference","isActive":true},{"text":" in a rule.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"There are two halves to a custom verb: teaching the parser to ","type":"text"},{"inlineContent":[{"text":"recognize","type":"text"}],"type":"emphasis"},{"text":" it, and writing a rule to ","type":"text"},{"inlineContent":[{"type":"text","text":"respond"}],"type":"emphasis"},{"text":" to it.","type":"text"}]},{"anchor":"Declare-the-verb","level":2,"type":"heading","text":"Declare the verb"},{"type":"paragraph","inlineContent":[{"text":"List new verbs in your game’s ","type":"text"},{"code":"verbs","type":"codeVoice"},{"text":" block. Each ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule","isActive":true,"type":"reference"},{"text":" is a ","type":"text"},{"inlineContent":[{"type":"text","text":"pattern"}],"type":"emphasis"},{"text":": the words the player types, in order, with slots where noun phrases (or a direction) go. String literals in a pattern are literal words; the slots are ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxElement\/directObject","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxElement\/indirectObject","isActive":true,"type":"reference"},{"text":", and ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxElement\/direction","isActive":true,"type":"reference"},{"text":". The row produces an ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent","type":"reference","isActive":true},{"text":" on a match:","type":"text"}]},{"type":"codeListing","code":["struct Temple: Game {","    static let ring = Intent(\"ring\")","","    let bell = Item { name(\"brass bell\") }","","    var verbs: [SyntaxRule] {","        SyntaxRule(\"ring\", .directObject, intent: Self.ring)","    }","    \/\/ rules below","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Exposing the intent as a "},{"type":"codeVoice","code":"static let"},{"type":"text","text":" constant lets your rules refer to the same intent the verb emits, without re-spelling the string."}]},{"level":2,"type":"heading","text":"Shape the pattern","anchor":"Shape-the-pattern"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A pattern reads the way it’s typed. Some shapes, from the standard table and beyond:"}]},{"rows":[[[{"inlineContent":[{"type":"text","text":"Pattern"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Player types"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Command gets"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"SyntaxRule(\"pray\", intent: …)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"pray","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"just the intent"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"SyntaxRule(\"dig\", .direction, intent: …)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"dig down"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/direction"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"SyntaxRule(\"ring\", .directObject, intent: …)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"ring bell"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/directObject"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"SyntaxRule(\"pick\", .directObject, \"up\", intent: …)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"pick bell up"}],"type":"paragraph"}],[{"inlineContent":[{"text":"a direct object","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"SyntaxRule(\"give\", .directObject, \"to\", .indirectObject, intent: …)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"give bell to monk","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"direct + indirect objects"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"SyntaxRule(\"look\", \"under\", .directObject, intent: …)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"look under rug","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"a direct object"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The rules: a pattern starts with at least one literal word (the verb); it can hold at most one direct-object and one indirect-object slot, direct first, with a literal word between them; a direction slot ends its pattern and never mixes with object slots. The bootstrap validates every custom row and reports malformed patterns as fatal diagnostics, all at once."}]},{"type":"paragraph","inlineContent":[{"text":"When both ","type":"text"},{"type":"codeVoice","code":"turn on lamp"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"turn lamp on"},{"text":" should work, register both orders — several rows can share one intent, which is also how synonyms work:","type":"text"}]},{"code":["var verbs: [SyntaxRule] {","    SyntaxRule(\"ring\",  .directObject, intent: Self.ring)","    SyntaxRule(\"sound\", .directObject, intent: Self.ring)","    SyntaxRule(\"turn\", \"on\", .directObject, intent: Self.light)","    SyntaxRule(\"turn\", .directObject, \"on\", intent: Self.light)","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Among rows sharing a verb word, the parser tries the most specific pattern first (more literal words, then more slots); ties keep their table order. The literal word sealing the direct object ahead of an indirect slot arrives on ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/preposition","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"level":2,"anchor":"Respond-to-the-intent","text":"Respond to the intent","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"A custom intent has no built-in default action, so a bare ","type":"text"},{"code":"ring bell","type":"codeVoice"},{"text":" would just report that the game didn’t understand. Give it behavior with a ","type":"text"},{"code":"before","type":"codeVoice"},{"text":" rule that ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/reply(_:)"},{"text":"s — ","type":"text"},{"code":"reply","type":"codeVoice"},{"text":" handles the action in place of any default:","type":"text"}]},{"code":["var rules: Rules {","    bell.before(Self.ring) {","        try reply(\"The bell tolls, deep and sonorous. Somewhere, a door unlatches.\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the object resolved into "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/directObject","isActive":true},{"type":"text","text":", you can attach the rule to the object ("},{"code":"bell.before(…)","type":"codeVoice"},{"type":"text","text":") or handle the intent more broadly on the "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/World","isActive":true},{"type":"text","text":" when several objects share behavior:"}]},{"code":["world.before(Self.ring) {","    guard let thing = command.directObject else {","        try refuse(\"Ring what?\")","    }","    try reply(\"You ring the \\(thing.name). Nothing happens.\")","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Reclaiming-a-built-in-verb","type":"heading","level":2,"text":"Reclaiming a built-in verb"},{"type":"paragraph","inlineContent":[{"text":"A verb table merges the built-in rows, each content bundle’s, each plugin’s, and the game’s own, under a ","type":"text"},{"inlineContent":[{"type":"text","text":"last-wins"}],"type":"strong"},{"text":" policy keyed on what the player types (the full pattern). If your row’s pattern exactly matches a built-in, yours reclaims it — the parser emits ","type":"text"},{"inlineContent":[{"type":"text","text":"your"}],"type":"emphasis"},{"text":" intent instead — and the engine logs a non-fatal warning so the override is never silent. This lets a game repurpose, say, ","type":"text"},{"code":"read","type":"codeVoice"},{"text":" without forking the engine.","type":"text"}]},{"anchor":"Where-verbs-can-come-from","type":"heading","level":2,"text":"Where verbs can come from"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"verbs"},{"text":" block exists on more than the game type. A ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GameContent","type":"reference"},{"text":" bundle and a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin","type":"reference"},{"text":" each carry their own ","type":"text"},{"type":"codeVoice","code":"verbs"},{"text":", all merged into one table at startup. That is exactly how a reusable commerce plugin ships ","type":"text"},{"type":"codeVoice","code":"buy"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"sell"},{"type":"text","text":" for any host to splice in — see "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Plugins","isActive":true},{"type":"text","text":"."}]},{"level":2,"anchor":"See-also","type":"heading","text":"See also"},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules","isActive":true,"type":"reference"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline","type":"reference"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Plugins","isActive":true,"type":"reference"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"references":{"doc://Gnusto/documentation/Gnusto":{"role":"collection","kind":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto","type":"topic","title":"Gnusto","url":"\/documentation\/gnusto","abstract":[{"type":"text","text":"A Swift engine for writing parser-driven interactive fiction — text adventures in the tradition of Zork and Infocom’s ZIL."}]},"doc://Gnusto/documentation/Gnusto/Command/direction":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/direction","type":"topic","title":"direction","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"direction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:6Gnusto9DirectionO","text":"Direction"},{"kind":"text","text":"?"}],"url":"\/documentation\/gnusto\/command\/direction","abstract":[{"type":"text","text":"The direction the player named, if any."}]},"doc://Gnusto/documentation/Gnusto/TheTurnPipeline":{"abstract":[{"type":"text","text":"What happens between the player pressing Return and the next prompt."}],"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline","title":"The Turn Pipeline","kind":"article","role":"article","url":"\/documentation\/gnusto\/theturnpipeline","type":"topic"},"doc://Gnusto/documentation/Gnusto/Plugins":{"role":"article","kind":"article","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Plugins","title":"Plugins","type":"topic","url":"\/documentation\/gnusto\/plugins","abstract":[{"type":"text","text":"Package a reusable game system as an importable unit of verbs and rules."}]},"doc://Gnusto/documentation/Gnusto/WritingRules":{"abstract":[{"type":"text","text":"Attach game logic to items, locations, and the world."}],"type":"topic","title":"Writing Rules","kind":"article","role":"article","url":"\/documentation\/gnusto\/writingrules","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules"},"doc://Gnusto/documentation/Gnusto/reply(_:)":{"kind":"symbol","abstract":[{"type":"text","text":"Fully handles the current action with a response, skipping the default"},{"type":"text","text":" "},{"text":"behavior. Mechanically identical to ","type":"text"},{"code":"refuse(_:)","type":"codeVoice"},{"type":"text","text":" — two names exist so"},{"type":"text","text":" "},{"type":"text","text":"game code reads correctly: "},{"type":"codeVoice","code":"refuse"},{"type":"text","text":" for “no, you can’t”, "},{"type":"codeVoice","code":"reply"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"“here’s what happens instead”."}],"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reply"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Never","kind":"typeIdentifier","preciseIdentifier":"s:s5NeverO"}],"url":"\/documentation\/gnusto\/reply(_:)","role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/reply(_:)","title":"reply(_:)"},"doc://Gnusto/documentation/Gnusto/World":{"kind":"symbol","abstract":[{"text":"Rules that apply everywhere, declared through the ","type":"text"},{"type":"codeVoice","code":"world"},{"text":" identifier in a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"rules"},{"text":" block:","type":"text"}],"navigatorTitle":[{"text":"World","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"World","kind":"identifier"}],"url":"\/documentation\/gnusto\/world","role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/World","title":"World"},"doc://Gnusto/documentation/Gnusto/Intent":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Intent"}],"abstract":[{"text":"A canonical action the player can attempt. Games can mint their own","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"Intent(\"ring\")","type":"codeVoice"},{"text":") and register verbs and default behavior for them.","type":"text"}],"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent","navigatorTitle":[{"kind":"identifier","text":"Intent"}],"title":"Intent","url":"\/documentation\/gnusto\/intent","kind":"symbol","type":"topic","role":"symbol"},"doc://Gnusto/documentation/Gnusto/SyntaxElement":{"navigatorTitle":[{"kind":"identifier","text":"SyntaxElement"}],"role":"symbol","title":"SyntaxElement","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxElement","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SyntaxElement"}],"url":"\/documentation\/gnusto\/syntaxelement","abstract":[{"text":"One element of a verb pattern: a literal word the player must type, or a","type":"text"},{"text":" ","type":"text"},{"text":"slot the parser fills from the rest of the sentence. String literals in a","type":"text"},{"text":" ","type":"text"},{"text":"pattern are ","type":"text"},{"type":"codeVoice","code":".word"},{"text":"s, so rows read the way they’re typed:","type":"text"}]},"doc://Gnusto/documentation/Gnusto/Command/directObject":{"type":"topic","url":"\/documentation\/gnusto\/command\/directobject","title":"directObject","role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/directObject","kind":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"directObject","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Item","preciseIdentifier":"s:6Gnusto4ItemV","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"abstract":[{"text":"The primary item the command acts on, if any.","type":"text"}]},"doc://Gnusto/documentation/Gnusto/Command/preposition":{"title":"preposition","abstract":[{"type":"text","text":"The preposition the player used, if any."}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"preposition","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/preposition","kind":"symbol","url":"\/documentation\/gnusto\/command\/preposition","type":"topic"},"doc://Gnusto/documentation/Gnusto/GamePlugin":{"navigatorTitle":[{"kind":"identifier","text":"GamePlugin"}],"role":"symbol","title":"GamePlugin","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GamePlugin","type":"topic","kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"GamePlugin"}],"url":"\/documentation\/gnusto\/gameplugin","abstract":[{"text":"A reusable game system — commerce, combat, dialog, magic — packaged as an","type":"text"},{"text":" ","type":"text"},{"text":"importable unit of ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"verbs"}]},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"rules"}]},{"type":"text","text":", that a host game opts into."}]},"doc://Gnusto/documentation/Gnusto/SyntaxElement/direction":{"title":"SyntaxElement.direction","abstract":[{"text":"A compass direction.","type":"text"}],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"direction"}],"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxElement\/direction","kind":"symbol","type":"topic","url":"\/documentation\/gnusto\/syntaxelement\/direction"},"doc://Gnusto/documentation/Gnusto/SyntaxElement/indirectObject":{"type":"topic","url":"\/documentation\/gnusto\/syntaxelement\/indirectobject","title":"SyntaxElement.indirectObject","role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxElement\/indirectObject","kind":"symbol","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"indirectObject"}],"abstract":[{"text":"The secondary noun phrase.","type":"text"}]},"doc://Gnusto/documentation/Gnusto/SyntaxElement/directObject":{"title":"SyntaxElement.directObject","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxElement\/directObject","abstract":[{"type":"text","text":"The primary noun phrase."}],"kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/gnusto\/syntaxelement\/directobject","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"directObject","kind":"identifier"}]},"doc://Gnusto/documentation/Gnusto/GameContent":{"abstract":[{"text":"A self-contained slice of a game’s world: its own rooms, items, and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"@Global"},{"text":" state, plus the geography, rules, and verbs that go with them.","type":"text"}],"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GameContent","title":"GameContent","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GameContent","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"GameContent"}],"role":"symbol","url":"\/documentation\/gnusto\/gamecontent","type":"topic"},"doc://Gnusto/documentation/Gnusto/SyntaxRule":{"abstract":[{"type":"text","text":"One row of the verb table: a pattern of literal words and slots, and the"},{"type":"text","text":" "},{"type":"text","text":"intent a match produces. Data, not code — games can add rows through their"},{"type":"text","text":" "},{"type":"codeVoice","code":"verbs"},{"type":"text","text":" block to teach the parser new player-typeable verbs."}],"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/SyntaxRule","title":"SyntaxRule","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SyntaxRule","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"SyntaxRule","kind":"identifier"}],"role":"symbol","url":"\/documentation\/gnusto\/syntaxrule","type":"topic"}}}