{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules"},"sections":[],"seeAlsoSections":[{"anchor":"Writing-Rules","identifiers":["doc:\/\/Gnusto\/documentation\/Gnusto\/Rule","doc:\/\/Gnusto\/documentation\/Gnusto\/Rules","doc:\/\/Gnusto\/documentation\/Gnusto\/Intent","doc:\/\/Gnusto\/documentation\/Gnusto\/Command","doc:\/\/Gnusto\/documentation\/Gnusto\/say(_:)","doc:\/\/Gnusto\/documentation\/Gnusto\/refuse(_:)","doc:\/\/Gnusto\/documentation\/Gnusto\/reply(_:)","doc:\/\/Gnusto\/documentation\/Gnusto\/end(won:)"],"title":"Writing Rules","generated":true}],"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"roleHeading":"Article","modules":[{"name":"Gnusto"}],"role":"article","title":"Writing Rules"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gnusto\/writingrules"]}],"hierarchy":{"paths":[["doc:\/\/Gnusto\/documentation\/Gnusto"]]},"abstract":[{"text":"Attach game logic to items, locations, and the world.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Rules are where a game stops being a map of static rooms and starts reacting. A rule is a phase (when it runs), an owner (what it watches), an optional set of intents (which actions it cares about), and a body of ordinary Swift that reads and writes the live world.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Every rule lives in a game’s ","type":"text"},{"type":"codeVoice","code":"rules"},{"text":" block, which yields a ","type":"text"},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Rules","isActive":true},{"text":" value:","type":"text"}]},{"type":"codeListing","code":["var rules: Rules {","    cloak.after(.take, .wear)  { bar.isLit = false }","    bar.beforeEachTurn         { … }","    world.after(.go)           { … }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide is a catalogue of what you can attach and how the bodies read state. For the order rules fire in, see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline"},{"type":"text","text":"."}]},{"type":"heading","text":"Choose an owner and a phase","level":2,"anchor":"Choose-an-owner-and-a-phase"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A rule is created by a factory method on the thing it watches. Three owners are available:"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Owner"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Factories"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"before"},{"type":"text","text":", "},{"type":"codeVoice","code":"after"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"before"},{"text":", ","type":"text"},{"type":"codeVoice","code":"after"},{"text":", ","type":"text"},{"type":"codeVoice","code":"beforeEachTurn"},{"text":", ","type":"text"},{"type":"codeVoice","code":"afterEachTurn"},{"text":", ","type":"text"},{"type":"codeVoice","code":"onEnter"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/World","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"before"},{"type":"text","text":", "},{"type":"codeVoice","code":"after"},{"type":"text","text":", "},{"type":"codeVoice","code":"beforeEachTurn"},{"type":"text","text":", "},{"type":"codeVoice","code":"afterEachTurn"}]}]]],"header":"row"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"before(_:perform:)"},{"text":" runs before the default action, for the listed intents. Veto the action with ","type":"text"},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/refuse(_:)","isActive":true},{"text":", or handle it yourself with ","type":"text"},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/reply(_:)","isActive":true},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"after(_:perform:)"},{"text":" runs after the default action succeeded, for the listed intents. React to what happened.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"beforeEachTurn"},{"text":" \/ ","type":"text"},{"type":"codeVoice","code":"afterEachTurn"},{"text":" run on ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"every"}]},{"text":" turn spent in the location (or, on ","type":"text"},{"type":"codeVoice","code":"world"},{"text":", everywhere) regardless of intent — the home for daemons and timers. ","type":"text"},{"type":"codeVoice","code":"afterEachTurn"},{"text":" runs even on refused turns, because world time still passes.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"onEnter"},{"text":" (locations only) runs the moment the player arrives, just before the room is auto-described.","type":"text"}]}]}]},{"type":"heading","text":"Match specific intents","level":2,"anchor":"Match-specific-intents"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The intents you pass to "},{"type":"codeVoice","code":"before"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"after"},{"type":"text","text":" filter the rule. List one or several; list none to match every action."}]},{"type":"codeListing","code":["\/\/ Only when the player tries to take OR wear the cloak:","cloak.before(.take, .wear) { … }","","\/\/ On any action targeting the statue:","statue.before() { say(\"The statue's eyes seem to follow you.\") }"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The built-in intents are constants on "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent","isActive":true},{"type":"text","text":" ("},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent\/take","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent\/drop","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent\/examine","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Intent\/go","isActive":true},{"type":"text","text":", and so on). Custom verbs mint their own — "},{"type":"codeVoice","code":"Intent(\"ring\")"},{"type":"text","text":" — which you match the same way. See "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/AddingCustomVerbs","isActive":true},{"type":"text","text":"."}]},{"type":"heading","text":"Read and write live state","level":2,"anchor":"Read-and-write-live-state"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Inside a rule body, your declarations "},{"type":"emphasis","inlineContent":[{"type":"text","text":"are"}]},{"type":"text","text":" the live entities. The bare identifiers "},{"type":"codeVoice","code":"player"},{"type":"text","text":", "},{"type":"codeVoice","code":"command"},{"type":"text","text":", "},{"type":"codeVoice","code":"world"},{"type":"text","text":", and every room and item you declared resolve to the current turn’s state."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Items expose "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item\/isHeld","isActive":true},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item\/isWorn"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item\/isTouched"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item\/name"},{"type":"text","text":", a settable "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item\/description","isActive":true},{"type":"text","text":", "},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item\/holds(_:)","isActive":true,"type":"reference"},{"type":"text","text":", and the movers "},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item\/move(to:)","isActive":true,"type":"reference"},{"type":"text","text":" and "},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item\/vanish()","isActive":true,"type":"reference"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["lever.after(.take) {","    say(\"It comes loose in your hand.\")","    trapdoor.description = \"The trapdoor now stands open.\"","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Locations expose a settable "},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/isLit","isActive":true,"type":"reference"},{"type":"text","text":", "},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/isVisited","isActive":true,"type":"reference"},{"type":"text","text":", "},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/contains(_:)","isActive":true,"type":"reference"},{"type":"text","text":", "},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/name","isActive":true,"type":"reference"},{"type":"text","text":", and a settable "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/description"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["cloak.after(.drop, .putOn) { bar.isLit = true }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The player exposes a settable "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Player\/location","isActive":true},{"type":"text","text":" (assigning teleports without describing the destination), a settable "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Player\/score","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Player\/moves","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Player\/isCarrying(_:)","isActive":true},{"type":"text","text":", and "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Player\/isWearing(_:)","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["message.before(.read) {","    player.score += 1","    say(message.description)","    try end(won: true)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The command being performed is available as "},{"type":"codeVoice","code":"command"},{"type":"text","text":" ("},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command","isActive":true},{"type":"text","text":"): its "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/intent","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/directObject","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/indirectObject","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/direction","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/preposition","isActive":true},{"type":"text","text":", and the raw "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Command\/verbPhrase","isActive":true},{"type":"text","text":" the player typed."}]},{"type":"codeListing","syntax":"swift","code":["bar.beforeEachTurn {","    guard !bar.isLit else { return }","    if command.intent == .go, command.direction == .north { return }","    try refuse(\"Blundering around in the dark isn't a good idea!\")","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For state the engine doesn’t already track — a wallet, an item’s price, a creature’s HP — reach for a "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Global","isActive":true},{"type":"text","text":" or a custom trait. See "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/CustomStateAndTraits","isActive":true},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Produce output and control the turn","anchor":"Produce-output-and-control-the-turn"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Four free functions are available in any rule body:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/say(_:)","isActive":true,"type":"reference"},{"type":"text","text":" — add a line to the turn’s output and keep going. The default action still runs."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/refuse(_:)","isActive":true,"type":"reference"},{"type":"text","text":" — print a complaint and abort the action (and remaining rules)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/reply(_:)","isActive":true,"type":"reference"},{"type":