mand"},{"type":"text","text":"."}],"url":"\/documentation\/gnusto\/command","navigatorTitle":[{"kind":"identifier","text":"Command"}]},"doc://Gnusto/documentation/Gnusto/WritingRules":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules","url":"\/documentation\/gnusto\/writingrules","kind":"article","role":"article","title":"Writing Rules","abstract":[{"type":"text","text":"Attach game logic to items, locations, and the world."}]},"doc://Gnusto/documentation/Gnusto/EntityID":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/EntityID","type":"topic","kind":"symbol","title":"EntityID","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"EntityID"}],"abstract":[{"type":"text","text":"A stable, human-readable entity name derived from the Swift property label"},{"type":"text","text":" "},{"type":"text","text":"at registration time ("},{"type":"codeVoice","code":"let bar = Location { … }"},{"type":"text","text":" → "},{"type":"codeVoice","code":"EntityID(\"bar\")"},{"type":"text","text":")."}],"url":"\/documentation\/gnusto\/entityid","navigatorTitle":[{"kind":"identifier","text":"EntityID"}]},"doc://Gnusto/documentation/Gnusto/ContentBundles":{"role":"article","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/ContentBundles","type":"topic","kind":"article","title":"Content Bundles","abstract":[{"text":"Give a region its own declarations — its own type, and even its own package.","type":"text"}],"url":"\/documentation\/gnusto\/contentbundles"},"doc://Gnusto/documentation/Gnusto/Item/isWorn":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item\/isWorn","type":"topic","kind":"symbol","title":"isWorn","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"isWorn"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"abstract":[{"type":"text","text":"True if the player is wearing the item."}],"url":"\/documentation\/gnusto\/item\/isworn"},"doc://Gnusto/documentation/Gnusto/Rules":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Rules","type":"topic","kind":"symbol","title":"Rules","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Rules"}],"abstract":[{"type":"text","text":"The collected rules of a game, declared in one "},{"type":"codeVoice","code":"rules"},{"type":"text","text":" block. Large games"},{"type":"text","text":" "},{"type":"text","text":"compose: "},{"type":"codeVoice","code":"var rules: Rules { cloakRules; barRules }"},{"type":"text","text":"."}],"url":"\/documentation\/gnusto\/rules","navigatorTitle":[{"kind":"identifier","text":"Rules"}]},"doc://Gnusto/documentation/Gnusto/Game":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Game","type":"topic","kind":"symbol","title":"Game","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Game"}],"abstract":[{"type":"text","text":"A complete game: declarations, geography, and rules."}],"url":"\/documentation\/gnusto\/game","navigatorTitle":[{"kind":"identifier","text":"Game"}]},"doc://Gnusto/documentation/Gnusto/Item/==(_:_:)":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item\/==(_:_:)","url":"\/documentation\/gnusto\/item\/==(_:_:)","kind":"symbol","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"==","kind":"identifier"},{"text":" ","kind":"text"},{"text":"(","kind":"text"},{"text":"Item","kind":"typeIdentifier","preciseIdentifier":"s:6Gnusto4ItemV"},{"text":", ","kind":"text"},{"text":"Item","kind":"typeIdentifier","preciseIdentifier":"s:6Gnusto4ItemV"},{"text":") -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"title":"==(_:_:)","abstract":[{"type"