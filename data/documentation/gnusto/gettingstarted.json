{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/Gnusto\/documentation\/Gnusto\/GettingStarted","interfaceLanguage":"swift"},"kind":"article","metadata":{"role":"article","title":"Getting Started with Gnusto","roleHeading":"Article","modules":[{"name":"Gnusto"}]},"seeAlsoSections":[{"title":"Essentials","generated":true,"anchor":"Essentials","identifiers":["doc:\/\/Gnusto\/documentation\/Gnusto\/AnatomyOfAGame","doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"inlineContent":[{"type":"text","text":"This guide walks you from an empty package to a small, playable game. By the end you will have declared two rooms and an object, wired them together, added a rule, and run the whole thing at a prompt. It assumes you can write basic Swift; it assumes nothing about interactive fiction."}],"type":"paragraph"},{"type":"heading","text":"Add Gnusto to your package","anchor":"Add-Gnusto-to-your-package","level":2},{"inlineContent":[{"type":"text","text":"Add Gnusto as a dependency and list it in your executable target:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ swift-tools-version: 6.2","import PackageDescription","","let package = Package(","    name: \"MyGame\",","    platforms: [.macOS(.v15)],","    dependencies: [","        .package(url: \"https:\/\/github.com\/HeirloomLogic\/Gnusto\", from: \"0.1.0\")","    ],","    targets: [","        .executableTarget(","            name: \"MyGame\",","            dependencies: [\"Gnusto\"]","        )","    ]",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Gnusto requires macOS 15 or newer (it uses "},{"type":"codeVoice","code":"Synchronization.Mutex"},{"type":"text","text":"), and builds with the Swift 6 language mode."}]},{"type":"heading","level":2,"anchor":"Declare-a-game","text":"Declare a game"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A game is a single type conforming to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Game"},{"type":"text","text":". Start with just a title and an intro:"}]},{"syntax":"swift","type":"codeListing","code":["import Gnusto","","struct MyGame: Game {","    let title = \"My First Game\"","    let intro = \"A cool breeze drifts down the hall.\"","}"]},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Game"},{"type":"text","text":" requires an "},{"type":"codeVoice","code":"init()"},{"type":"text","text":", but Swift synthesizes it for free as long as every stored property has a default value — which they always will here, since rooms, items, and state are declared with initializers."}]},{"type":"heading","level":2,"anchor":"Add-a-room","text":"Add a room"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Declare a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location"},{"type":"text","text":" as a stored property. The property name ("},{"type":"codeVoice","code":"hall"},{"type":"text","text":") becomes the room’s internal identity; the "},{"type":"codeVoice","code":"name(_:)"},{"type":"text","text":" trait is what the player sees."}]},{"syntax":"swift","type":"codeListing","code":["struct MyGame: Game {","    let title = \"My First Game\"","    let intro = \"A cool breeze drifts down the hall.\"","","    let hall = Location {","        name(\"Entrance Hall\")","        description(\"A long hall of grey stone. A doorway opens to the north.\")","    }","","    var map: WorldMap {","        player.starts(in: hall)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"map"},{"type":"text","text":" block is where geography and starting positions live. "},{"type":"codeVoice","code":"player.starts(in:)"},{"type":"text","text":" places the player; without it, the game has nowhere to begin."}]},{"type":"heading","level":2,"anchor":"Run-it","text":"Run it"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Three lines turn a game value into a running session:"}]},{"syntax":"swift","type":"codeListing","code":["let world = try GameWorld(game: MyGame())","await REPL(world: world, io: ConsoleIOHandler()).run()"]},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GameWorld"},{"type":"text","text":" validates the game and builds its initial state up front — a mistake like an exit to an undeclared room is caught here, as a thrown "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/BootstrapError"},{"type":"text","text":", not at runtime. "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/REPL"},{"type":"text","text":" runs the prompt\/parse\/perform\/print loop, and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/ConsoleIOHandler"},{"type":"text","text":" reads from and writes to the terminal."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Wrap it in a "},{"type":"codeVoice","code":"do"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"catch"},{"type":"text","text":" in your "},{"type":"codeVoice","code":"main.swift"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["import Gnusto","","do {","    let world = try GameWorld(game: MyGame())","    await REPL(world: world, io: ConsoleIOHandler()).run()","} catch {","    print(\"Couldn't start the game: \\(error)\")","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Run "},{"type":"codeVoice","code":"swift run"},{"type":"text","text":", and you can already "},{"type":"codeVoice","code":"look"},{"type":"text","text":" around and try to move."}]},{"type":"heading","level":2,"anchor":"Add-a-second-room-and-connect-them","text":"Add a second room and connect them"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Exits are declared on locations in the "},{"type":"codeVoice","code":"map"},{"type":"text","text":" block. Each directional method ("},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/north(_:)"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/south(_:)"},{"type":"text","text":", …) is an ordinary property reference, so a typo or a renamed room is a compile error, not a broken game."}]},{"syntax":"swift","type":"codeListing","code":["let hall = Location {","    name(\"Entrance Hall\")","    description(\"A long hall of grey stone. A doorway opens to the north.\")","}","","let library = Location {","    name(\"Dusty Library\")","    description(\"Shelves sag under mildewed books. The hall lies south.\")","}","","var map: WorldMap {","    hall.north(library)","    library.south(hall)","","    player.starts(in: hall)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Exits are one-directional by design — declare both "},{"type":"codeVoice","code":"hall.north(library)"},{"type":"text","text":" and "},{"type":"codeVoice","code":"library.south(hall)"},{"type":"text","text":" if you want the player to be able to walk back."}]},{"type":"heading","level":2,"anchor":"Add-a-thing","text":"Add a thing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Declare an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item"},{"type":"text","text":" the same way, then place it in the "},{"type":"codeVoice","code":"map"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["let lantern = Item {","    name(\"brass lantern\")","    adjectives(\"brass\", \"old\")","    description(\"An old brass lantern, its glass sooty but intact.\")","}","","var map: WorldMap {","    hall.north(library)","    library.south(hall)","","    player.starts(in: hall)","    lantern.starts(in: library)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Now the player can walk "},{"type":"codeVoice","code":"north"},{"type":"text","text":", "},{"type":"codeVoice","code":"examine lantern"},{"type":"text","text":", "},{"type":"codeVoice","code":"take lantern"},{"type":"text","text":", and see it in their "},{"type":"codeVoice","code":"inventory"},{"type":"text","text":". The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/adjectives(_:)"},{"type":"text","text":" let them type "},{"type":"codeVoice","code":"take brass lantern"},{"type":"text","text":" or just "},{"type":"codeVoice","code":"take brass"},{"type":"text","text":". The last word of "},{"type":"codeVoice","code":"name(_:)"},{"type":"text","text":" (“lantern”) is the noun the parser keys on."}]},{"type":"heading","level":2,"anchor":"React-with-a-rule","text":"React with a rule"},{"type":"paragraph","inlineContent":[{"type":"text","text":"So far every verb uses its built-in behavior. To add your own logic, write a rule in the "},{"type":"codeVoice","code":"rules"},{"type":"text","text":" block. Rules are "},{"type":"codeVoice","code":"before"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"after"},{"type":"text","text":" hooks attached to a location, an item, or the whole world."}]},{"syntax":"swift","type":"codeListing","code":["var rules: Rules {","    lantern.after(.take) {","        say(\"It's heavier than it looks.\")","    }","","    library.before(.go) {","        guard command.direction != .south else { return }","        try refuse(\"There's no exit that way — only back south to the hall.\")","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first rule runs "},{"type":"emphasis","inlineContent":[{"type":"text","text":"after"}]},{"type":"text","text":" the player successfully takes the lantern and adds a line of flavor with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/say(_:)"},{"type":"text","text":". The second runs "},{"type":"emphasis","inlineContent":[{"type":"text","text":"before"}]},{"type":"text","text":" movement in the library and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/refuse(_:)"},{"type":"text","text":"s any direction but south. Inside a rule body, bare identifiers like "},{"type":"codeVoice","code":"command"},{"type":"text","text":", "},{"type":"codeVoice","code":"player"},{"type":"text","text":", and your own "},{"type":"codeVoice","code":"lantern"},{"type":"text","text":" refer to the live turn — reading and writing them touches the current game state."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To learn what rules can do — the phases, the ordering, and the difference between "},{"type":"codeVoice","code":"refuse"},{"type":"text","text":", "},{"type":"codeVoice","code":"reply"},{"type":"text","text":", "},{"type":"codeVoice","code":"say"},{"type":"text","text":", and "},{"type":"codeVoice","code":"end"},{"type":"text","text":" — read "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline"},{"type":"text","text":"."}]},{"type":"heading","level":2,"anchor":"A-fuller-example","text":"A fuller example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Gnusto ships with "},{"type":"strong","inlineContent":[{"type":"text","text":"Cloak of Darkness"}]},{"type":"text","text":", Roger Firth’s classic one-room demonstration game, as its "},{"type":"codeVoice","code":"CloakOfDarkness"},{"type":"text","text":" target. It exercises nearly every feature in a page of code — dark rooms, a wearable cloak, scored actions, a losing state, and per-turn rules — and is worth reading start to finish once the basics click."}]},{"type":"heading","level":2,"anchor":"Next-steps","text":"Next steps"},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/AnatomyOfAGame","isActive":true,"type":"reference"},{"type":"text","text":" — how declarations, identity, and live references fit together"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline","isActive":true,"type":"reference"},{"type":"text","text":" — exactly what happens each turn"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules","isActive":true,"type":"reference"},{"type":"text","text":" — the full vocabulary of game logic"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/CustomStateAndTraits","isActive":true,"type":"reference"},{"type":"text","text":" — carry your own data on entities and in globals"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"abstract":[{"type":"text","text":"Build and run your first text adventure, one piece at a time."}],"variants":[{"paths":["\/documentation\/gnusto\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/Gnusto\/documentation\/Gnusto"]]},"references":{"doc://Gnusto/documentation/Gnusto/REPL":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/REPL","url":"\/documentation\/gnusto\/repl","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"REPL","kind":"identifier"}],"navigatorTitle":[{"text":"REPL","kind":"identifier"}],"abstract":[{"type":"text","text":"The outer loop: prompt → parse → perform → print, until the game ends or"},{"type":"text","text":" "},{"type":"text","text":"input runs out. Holds the only "},{"type":"codeVoice","code":"await"},{"type":"text","text":" in a Gnusto game."}],"title":"REPL"},"doc://Gnusto/documentation/Gnusto/GameWorld":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GameWorld","type":"topic","kind":"symbol","title":"GameWorld","fragments":[{"kind":"keyword","text":"actor"},{"kind":"text","text":" "},{"kind":"identifier","text":"GameWorld"}],"abstract":[{"type":"text","text":"The game world: owns all state, serializes all mutation, and runs the"},{"type":"text","text":" "},{"type":"text","text":"turn pipeline. The single "},{"type":"codeVoice","code":"await"},{"type":"text","text":" in a game sits between the REPL and"},{"type":"text","text":" "},{"type":"text","text":"this actor."}],"url":"\/documentation\/gnusto\/gameworld","navigatorTitle":[{"kind":"identifier","text":"GameWorld"}]},"doc://Gnusto/documentation/Gnusto/BootstrapError":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/BootstrapError","url":"\/documentation\/gnusto\/bootstraperror","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BootstrapError","kind":"identifier"}],"navigatorTitle":[{"text":"BootstrapError","kind":"identifier"}],"title":"BootstrapError","abstract":[{"type":"text","text":"All problems with a game definition, reported at once."}]},"doc://Gnusto/documentation/Gnusto":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto","url":"\/documentation\/gnusto","kind":"symbol","role":"collection","abstract":[{"type":"text","text":"A Swift engine for writing parser-driven interactive fiction — text adventures in the tradition of Zork and Infocom’s ZIL."}],"title":"Gnusto"},"doc://Gnusto/documentation/Gnusto/say(_:)":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/say(_:)","type":"topic","kind":"symbol","title":"say(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"say"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":")"}],"abstract":[{"type":"text","text":"Prints a message as part of the turn’s output."}],"url":"\/documentation\/gnusto\/say(_:)"},"doc://Gnusto/documentation/Gnusto/Location/south(_:)":{"abstract":[{"type":"text","text":"An exit leading south to "},{"type":"codeVoice","code":"to"},{"type":"text","text":"."}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"south"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Location","preciseIdentifier":"s:6Gnusto8LocationV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"MapEntry","preciseIdentifier":"s:6Gnusto8MapEntryV"}],"kind":"symbol","type":"topic","title":"south(_:)","role":"symbol","url":"\/documentation\/gnusto\/location\/south(_:)","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/south(_:)"},"doc://Gnusto/documentation/Gnusto/Item":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item","type":"topic","kind":"symbol","title":"Item","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Item"}],"abstract":[{"type":"text","text":"A thing in the world."}],"url":"\/documentation\/gnusto\/item","navigatorTitle":[{"kind":"identifier","text":"Item"}]},"doc://Gnusto/documentation/Gnusto/Location/north(_:)":{"abstract":[{"type":"text","text":"An exit leading north to "},{"type":"codeVoice","code":"to"},{"type":"text","text":"."}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"north"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:6Gnusto8LocationV","text":"Location"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:6Gnusto8MapEntryV","text":"MapEntry"}],"kind":"symbol","type":"topic","title":"north(_:)","role":"symbol","url":"\/documentation\/gnusto\/location\/north(_:)","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/north(_:)"},"doc://Gnusto/documentation/Gnusto/refuse(_:)":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/refuse(_:)","type":"topic","kind":"symbol","title":"refuse(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"refuse"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Never","preciseIdentifier":"s:s5NeverO"}],"abstract":[{"type":"text","text":"Blocks the current action with a complaint. The default action and any"},{"type":"text","text":" "},{"type":"text","text":"remaining "},{"type":"codeVoice","code":"before"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"after"},{"type":"text","text":" rules are skipped; world time still passes."}],"url":"\/documentation\/gnusto\/refuse(_:)"},"doc://Gnusto/documentation/Gnusto/Location":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location","type":"topic","kind":"symbol","title":"Location","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Location"}],"abstract":[{"type":"text","text":"A place in the world."}],"url":"\/documentation\/gnusto\/location","navigatorTitle":[{"kind":"identifier","text":"Location"}]},"doc://Gnusto/documentation/Gnusto/Game":{"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Game","type":"topic","kind":"symbol","title":"Game","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Game"}],"abstract":[{"type":"text","text":"A complete game: declarations, geography, and rules."}],"url":"\/documentation\/gnusto\/game","navigatorTitle":[{"kind":"identifier","text":"Game"}]},"doc://Gnusto/documentation/Gnusto/WritingRules":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules","url":"\/documentation\/gnusto\/writingrules","kind":"article","role":"article","title":"Writing Rules","abstract":[{"type":"text","text":"Attach game logic to items, locations, and the world."}]},"doc://Gnusto/documentation/Gnusto/ConsoleIOHandler":{"abstract":[{"type":"text","text":"Plain terminal IO."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConsoleIOHandler"}],"kind":"symbol","type":"topic","title":"ConsoleIOHandler","navigatorTitle":[{"kind":"identifier","text":"ConsoleIOHandler"}],"role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/ConsoleIOHandler","url":"\/documentation\/gnusto\/consoleiohandler"},"doc://Gnusto/documentation/Gnusto/AnatomyOfAGame":{"abstract":[{"type":"text","text":"How a single Swift type becomes a world the engine can run."}],"kind":"article","type":"topic","title":"Anatomy of a Game","role":"article","url":"\/documentation\/gnusto\/anatomyofagame","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/AnatomyOfAGame"},"doc://Gnusto/documentation/Gnusto/adjectives(_:)":{"type":"topic","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/adjectives(_:)","url":"\/documentation\/gnusto\/adjectives(_:)","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"adjectives"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"...) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:6Gnusto9ItemTraitV","text":"ItemTrait"}],"title":"adjectives(_:)","abstract":[{"type":"text","text":"Additional words the parser accepts before the item’s noun."}]},"doc://Gnusto/documentation/Gnusto/CustomStateAndTraits":{"role":"article","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/CustomStateAndTraits","type":"topic","kind":"article","title":"Custom State and Traits","abstract":[{"type":"text","text":"Carry your own data on entities and in globals, alongside the engine’s closed core."}],"url":"\/documentation\/gnusto\/customstateandtraits"},"doc://Gnusto/documentation/Gnusto/TheTurnPipeline":{"role":"article","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline","type":"topic","kind":"article","title":"The Turn Pipeline","abstract":[{"type":"text","text":"What happens between the player pressing Return and the next prompt."}],"url":"\/documentation\/gnusto\/theturnpipeline"}}}