{"hierarchy":{"paths":[["doc:\/\/Gnusto\/documentation\/Gnusto"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gnusto\/gettingstarted"]}],"seeAlsoSections":[{"generated":true,"anchor":"Essentials","title":"Essentials","identifiers":["doc:\/\/Gnusto\/documentation\/Gnusto\/AnatomyOfAGame","doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Article","title":"Getting Started with Gnusto","role":"article","modules":[{"name":"Gnusto"}]},"identifier":{"url":"doc:\/\/Gnusto\/documentation\/Gnusto\/GettingStarted","interfaceLanguage":"swift"},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"This guide walks you from an empty package to a small, playable game. By the end you will have declared two rooms and an object, wired them together, added a rule, and run the whole thing at a prompt. It assumes you can write basic Swift; it assumes nothing about interactive fiction.","type":"text"}]},{"type":"heading","anchor":"Add-Gnusto-to-your-package","text":"Add Gnusto to your package","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add Gnusto as a dependency and list it in your executable target:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ swift-tools-version: 6.2","import PackageDescription","","let package = Package(","    name: \"MyGame\",","    platforms: [.macOS(.v15)],","    dependencies: [","        .package(url: \"https:\/\/github.com\/HeirloomLogic\/Gnusto\", from: \"0.1.0\")","    ],","    targets: [","        .executableTarget(","            name: \"MyGame\",","            dependencies: [\"Gnusto\"]","        )","    ]",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Gnusto requires macOS 15 or newer (it uses "},{"code":"Synchronization.Mutex","type":"codeVoice"},{"type":"text","text":"), and builds with the Swift 6 language mode."}]},{"type":"heading","anchor":"Declare-a-game","text":"Declare a game","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A game is a single type conforming to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Game"},{"type":"text","text":". Start with just a title and an intro:"}]},{"type":"codeListing","syntax":"swift","code":["import Gnusto","","struct MyGame: Game {","    let title = \"My First Game\"","    let intro = \"A cool breeze drifts down the hall.\"","}"]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Game","isActive":true,"type":"reference"},{"text":" requires an ","type":"text"},{"type":"codeVoice","code":"init()"},{"text":", but Swift synthesizes it for free as long as every stored property has a default value — which they always will here, since rooms, items, and state are declared with initializers.","type":"text"}]},{"type":"heading","text":"Add a room","anchor":"Add-a-room","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Declare a "},{"isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location","type":"reference"},{"type":"text","text":" as a stored property. The property name ("},{"code":"hall","type":"codeVoice"},{"text":") becomes the room’s internal identity; the ","type":"text"},{"code":"name(_:)","type":"codeVoice"},{"text":" trait is what the player sees.","type":"text"}]},{"code":["struct MyGame: Game {","    let title = \"My First Game\"","    let intro = \"A cool breeze drifts down the hall.\"","","    let hall = Location {","        name(\"Entrance Hall\")","        description(\"A long hall of grey stone. A doorway opens to the north.\")","    }","","    var map: WorldMap {","        player.starts(in: hall)","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"map"},{"type":"text","text":" block is where geography and starting positions live. "},{"type":"codeVoice","code":"player.starts(in:)"},{"type":"text","text":" places the player; without it, the game has nowhere to begin."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Run it","anchor":"Run-it"},{"type":"paragraph","inlineContent":[{"text":"Three lines turn a game value into a running session:","type":"text"}]},{"type":"codeListing","code":["let world = try GameWorld(game: MyGame())","await REPL(world: world, io: ConsoleIOHandler()).run()"],"syntax":"swift"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GameWorld"},{"text":" validates the game and builds its initial state up front — a mistake like an exit to an undeclared room is caught here, as a thrown ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/BootstrapError"},{"text":", not at runtime. ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/REPL"},{"text":" runs the prompt\/parse\/perform\/print loop, and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/ConsoleIOHandler"},{"text":" reads from and writes to the terminal.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Wrap it in a ","type":"text"},{"type":"codeVoice","code":"do"},{"text":"\/","type":"text"},{"type":"codeVoice","code":"catch"},{"text":" in your ","type":"text"},{"type":"codeVoice","code":"main.swift"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import Gnusto","","do {","    let world = try GameWorld(game: MyGame())","    await REPL(world: world, io: ConsoleIOHandler()).run()","} catch {","    print(\"Couldn't start the game: \\(error)\")","}"],"type":"codeListing"},{"inlineContent":[{"text":"Run ","type":"text"},{"type":"codeVoice","code":"swift run"},{"text":", and you can already ","type":"text"},{"type":"codeVoice","code":"look"},{"text":" around and try to move.","type":"text"}],"type":"paragraph"},{"text":"Add a second room and connect them","level":2,"anchor":"Add-a-second-room-and-connect-them","type":"heading"},{"inlineContent":[{"type":"text","text":"Exits are declared on locations in the "},{"type":"codeVoice","code":"map"},{"type":"text","text":" block. Each directional method ("},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/north(_:)","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location\/south(_:)","isActive":true},{"type":"text","text":", …) is an ordinary property reference, so a typo or a renamed room is a compile error, not a broken game."}],"type":"paragraph"},{"type":"codeListing","code":["let hall = Location {","    name(\"Entrance Hall\")","    description(\"A long hall of grey stone. A doorway opens to the north.\")","}","","let library = Location {","    name(\"Dusty Library\")","    description(\"Shelves sag under mildewed books. The hall lies south.\")","}","","var map: WorldMap {","    hall.north(library)","    library.south(hall)","","    player.starts(in: hall)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Exits are one-directional by design — declare both ","type":"text"},{"type":"codeVoice","code":"hall.north(library)"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"library.south(hall)"},{"text":" if you want the player to be able to walk back.","type":"text"}]},{"type":"heading","text":"Add a thing","anchor":"Add-a-thing","level":2},{"type":"paragraph","inlineContent":[{"text":"Declare an ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Item","type":"reference","isActive":true},{"text":" the same way, then place it in the ","type":"text"},{"type":"codeVoice","code":"map"},{"text":":","type":"text"}]},{"code":["let lantern = Item {","    name(\"brass lantern\")","    adjectives(\"brass\", \"old\")","    description(\"An old brass lantern, its glass sooty but intact.\")","}","","var map: WorldMap {","    hall.north(library)","    library.south(hall)","","    player.starts(in: hall)","    lantern.starts(in: library)","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Now the player can walk ","type":"text"},{"code":"north","type":"codeVoice"},{"text":", ","type":"text"},{"code":"examine lantern","type":"codeVoice"},{"text":", ","type":"text"},{"code":"take lantern","type":"codeVoice"},{"text":", and see it in their ","type":"text"},{"code":"inventory","type":"codeVoice"},{"text":". The ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/adjectives(_:)","type":"reference","isActive":true},{"text":" let them type ","type":"text"},{"code":"take brass lantern","type":"codeVoice"},{"text":" or just ","type":"text"},{"code":"take brass","type":"codeVoice"},{"text":". The last word of ","type":"text"},{"code":"name(_:)","type":"codeVoice"},{"text":" (“lantern”) is the noun the parser keys on.","type":"text"}]},{"text":"React with a rule","type":"heading","anchor":"React-with-a-rule","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"So far every verb uses its built-in behavior. To add your own logic, write a rule in the "},{"code":"rules","type":"codeVoice"},{"type":"text","text":" block. Rules are "},{"code":"before","type":"codeVoice"},{"type":"text","text":"\/"},{"code":"after","type":"codeVoice"},{"type":"text","text":" hooks attached to a location, an item, or the whole world."}]},{"code":["var rules: Rules {","    lantern.after(.take) {","        say(\"It's heavier than it looks.\")","    }","","    library.before(.go) {","        guard command.direction != .south else { return }","        try refuse(\"There's no exit that way — only back south to the hall.\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The first rule runs ","type":"text"},{"inlineContent":[{"type":"text","text":"after"}],"type":"emphasis"},{"text":" the player successfully takes the lantern and adds a line of flavor with ","type":"text"},{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/say(_:)","type":"reference","isActive":true},{"text":". The second runs ","type":"text"},{"inlineContent":[{"type":"text","text":"before"}],"type":"emphasis"},{"text":" movement in the library and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/refuse(_:)"},{"text":"s any direction but south. Inside a rule body, bare identifiers like ","type":"text"},{"code":"command","type":"codeVoice"},{"text":", ","type":"text"},{"code":"player","type":"codeVoice"},{"text":", and your own ","type":"text"},{"code":"lantern","type":"codeVoice"},{"text":" refer to the live turn — reading and writing them touches the current game state.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To learn what rules can do — the phases, the ordering, and the difference between ","type":"text"},{"code":"refuse","type":"codeVoice"},{"text":", ","type":"text"},{"code":"reply","type":"codeVoice"},{"text":", ","type":"text"},{"code":"say","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"end","type":"codeVoice"},{"text":" — read ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline"},{"text":".","type":"text"}]},{"type":"heading","anchor":"A-fuller-example","text":"A fuller example","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Gnusto ships with "},{"inlineContent":[{"type":"text","text":"Cloak of Darkness"}],"type":"strong"},{"type":"text","text":", Roger Firth’s classic one-room demonstration game, as its "},{"type":"codeVoice","code":"CloakOfDarkness"},{"type":"text","text":" target. It exercises nearly every feature in a page of code — dark rooms, a wearable cloak, scored actions, a losing state, and per-turn rules — and is worth reading start to finish once the basics click."}]},{"type":"heading","anchor":"Next-steps","text":"Next steps","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/AnatomyOfAGame","type":"reference","isActive":true},{"text":" — how declarations, identity, and live references fit together","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline","isActive":true,"type":"reference"},{"text":" — exactly what happens each turn","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules","isActive":true},{"type":"text","text":" — the full vocabulary of game logic"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/CustomStateAndTraits"},{"text":" — carry your own data on entities and in globals","type":"text"}],"type":"paragraph"}]}]}]}],"abstract":[{"type":"text","text":"Build and run your first text adventure, one piece at a time."}],"references":{"doc://Gnusto/documentation/Gnusto":{"role":"collection","kind":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto","type":"topic","title":"Gnusto","url":"\/documentation\/gnusto","abstract":[{"type":"text","text":"A Swift engine for writing parser-driven interactive fiction — text adventures in the tradition of Zork and Infocom’s ZIL."}]},"doc://Gnusto/documentation/Gnusto/ConsoleIOHandler":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"ConsoleIOHandler"}],"url":"\/documentation\/gnusto\/consoleiohandler","title":"ConsoleIOHandler","role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/ConsoleIOHandler","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConsoleIOHandler"}],"abstract":[{"text":"Plain terminal IO.","type":"text"}]},"doc://Gnusto/documentation/Gnusto/Game":{"navigatorTitle":[{"kind":"identifier","text":"Game"}],"role":"symbol","title":"Game","type":"topic","kind":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Game","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Game"}],"url":"\/documentation\/gnusto\/game","abstract":[{"type":"text","text":"A complete game: declarations, geography, and rules."}]},"doc://Gnusto/documentation/Gnusto/GameWorld":{"kind":"symbol","abstract":[{"text":"The game world: owns all state, serializes all mutation, and runs the","type":"text"},{"text":" ","type":"text"},{"text":"turn pipeline. The single ","type":"text"},{"code":"await","type":"codeVoice"},{"text":" in a game sits between the REPL and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this actor."}],"navigatorTitle":[{"text":"GameWorld","kind":"identifier"}],"type":"topic","fragments":[{"text":"actor","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GameWorld","kind":"identifier"}],"url":"\/documentation\/gnusto\/gameworld","role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/GameWorld","title":"GameWorld"},"doc://Gnusto/documentation/Gnusto/WritingRules":{"abstract":[{"type":"text","text":"Attach game logic to items, locations, and the world."}],"type":"topic","title":"Writing Rules","kind":"article","role":"article","url":"\/documentation\/gnusto\/writingrules","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/WritingRules"},"doc://Gnusto/documentation/Gnusto/AnatomyOfAGame":{"kind":"article","abstract":[{"text":"How a single Swift type becomes a world the engine can run.","type":"text"}],"type":"topic","url":"\/documentation\/gnusto\/anatomyofagame","role":"article","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/AnatomyOfAGame","title":"Anatomy of a Game"},"doc://Gnusto/documentation/Gnusto/Location":{"title":"Location","abstract":[{"text":"A place in the world.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"Location"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Location","kind":"identifier"}],"url":"\/documentation\/gnusto\/location","role":"symbol","identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/Location","kind":"symbol"},"doc://Gnusto/documentation/Gnusto/TheTurnPipeline":{"abstract":[{"type":"text","text":"What happens between the player pressing Return and the next prompt."}],"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/TheTurnPipeline","title":"The Turn Pipeline","kind":"article","role":"article","url":"\/documentation\/gnusto\/theturnpipeline","type":"topic"},"doc://Gnusto/documentation/Gnusto/REPL":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"REPL","kind":"identifier"}],"abstract":[{"type":"text","text":"The outer loop: prompt → parse → perform → print, until the game ends or"},{"type":"text","text":" "},{"type":"text","text":"input runs out. Holds the only "},{"type":"codeVoice","code":"await"},{"type":"text","text":" in a Gnusto game."}],"identifier":"doc:\/\/Gnusto\/documentation\/Gnusto\/REPL","navigatorTitle":[{"text":"REPL","kind":"identifier"}],"url":"\/documentation\/gnusto\/repl","title":"REPL","kind":"symbol","type":"topic","role":"symbol"},"doc://Gnusto/documentation/Gnusto/BootstrapError":{"kind":"symbol","abstract":[{"type":"text","text":"All problems with a game definition, reported at once."}],"navigatorTitle":[{"text":"BootstrapError","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BootstrapError","kind